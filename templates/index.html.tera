<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Ducks in a Row Dashboard</title>
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />
  <style>
    body { background: #1a1d23; color: #e0e0e0; }
    .widget {
      background: #23272f;
      border-radius: 10px;
      padding: 1.25rem;
      height: 100%;
      min-height: 260px;
      display: flex;
      flex-direction: column;
    }
    .widget h6 {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #8a9bae;
      margin-bottom: 0.75rem;
    }
    .stat-value { font-size: 2rem; font-weight: 700; line-height: 1.1; }
    .stat-label { font-size: 0.8rem; color: #8a9bae; }
    .badge-critical { color: #ff5c5c; }
    .badge-high     { color: #ffb347; }
    .widget canvas  { flex: 1; }
    .duck-widget {
      align-items: center;
      justify-content: center;
      text-align: center;
    }
    .duck-emoji { font-size: 4rem; }
    .duck-date  { font-size: 1.1rem; font-weight: 600; margin-top: 0.5rem; }
    .duck-time  { font-size: 2.2rem; font-weight: 700; letter-spacing: 0.05em; }
    .ncentral-table { font-size: 0.8rem; }
    .ncentral-table th { color: #8a9bae; font-weight: 500; border-color: #33394a; }
    .ncentral-table td { border-color: #33394a; vertical-align: middle; }
    .weather-widget { align-items: center; justify-content: center; text-align: center; }
    .weather-temp { font-size: 3rem; font-weight: 700; }
    .weather-icon { font-size: 3rem; }
  </style>
</head>
<body>
<div class="container-fluid py-3 px-4">
  <h4 class="mb-3 fw-bold">🦆 Ducks in a Row</h4>
  <div class="row g-3">

    <!-- Widget 1: Wazuh -->
    <div class="col-4">
      <div class="widget">
        <h6>Wazuh</h6>
        <div class="d-flex gap-4 mb-3">
          <div>
            <div class="stat-value badge-critical" id="wazuh-critical">—</div>
            <div class="stat-label">Critical</div>
          </div>
          <div>
            <div class="stat-value badge-high" id="wazuh-high">—</div>
            <div class="stat-label">High</div>
          </div>
        </div>
        <canvas id="wazuhChart"></canvas>
      </div>
    </div>

    <!-- Widget 2: Atera -->
    <div class="col-4">
      <div class="widget">
        <h6>Atera</h6>
        <div class="d-flex gap-4 mb-3">
          <div>
            <div class="stat-value" id="atera-alerts">—</div>
            <div class="stat-label">Active Alerts</div>
          </div>
          <div>
            <div class="stat-value" id="atera-tickets">—</div>
            <div class="stat-label">Open Tickets</div>
          </div>
          <div>
            <div class="stat-value" id="atera-patches">—</div>
            <div class="stat-label">Pending Patches</div>
          </div>
        </div>
        <canvas id="ateraChart"></canvas>
      </div>
    </div>

    <!-- Widget 3: Vipre AV -->
    <div class="col-4">
      <div class="widget">
        <h6>Vipre AV</h6>
        <div class="d-flex flex-wrap gap-3 mb-3">
          <div>
            <div class="stat-value" id="vipre-outdated">—</div>
            <div class="stat-label">Outdated</div>
          </div>
          <div>
            <div class="stat-value" id="vipre-lost">—</div>
            <div class="stat-label">Lost</div>
          </div>
          <div>
            <div class="stat-value" id="vipre-no-av">—</div>
            <div class="stat-label">AD w/o AV</div>
          </div>
          <div>
            <div class="stat-value" id="vipre-no-ad">—</div>
            <div class="stat-label">AV w/o AD</div>
          </div>
        </div>
        <canvas id="vipreChart"></canvas>
      </div>
    </div>

    <!-- Widget 4: Backup -->
    <div class="col-4">
      <div class="widget">
        <h6>Backup Status</h6>
        <canvas id="backupChart"></canvas>
      </div>
    </div>

    <!-- Widget 5: AD Metrics -->
    <div class="col-4">
      <div class="widget">
        <h6>AD Metrics</h6>
        <div class="d-flex gap-4 mb-3">
          <div>
            <div class="stat-value" id="ad-expired">—</div>
            <div class="stat-label">Pwd Expired</div>
          </div>
          <div>
            <div class="stat-value" id="ad-locked">—</div>
            <div class="stat-label">Locked Out</div>
          </div>
        </div>
        <canvas id="adChart"></canvas>
      </div>
    </div>

    <!-- Widget 6: N-central -->
    <div class="col-4">
      <div class="widget">
        <h6>N-central Alerts</h6>
        <div class="table-responsive">
          <table class="table table-dark table-sm ncentral-table mb-0">
            <thead>
              <tr>
                <th>Device</th>
                <th>Service</th>
                <th>Type</th>
                <th>Since</th>
              </tr>
            </thead>
            <tbody id="ncentral-body">
              <tr><td colspan="4" class="text-center text-secondary">Loading…</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Widget 7: Veeam -->
    <div class="col-4">
      <div class="widget">
        <h6>Veeam Jobs</h6>
        <canvas id="veeamChart"></canvas>
      </div>
    </div>

    <!-- Widget 8: Weather -->
    <div class="col-4">
      <div class="widget weather-widget">
        <h6>Weather</h6>
        <div class="weather-icon" id="weather-icon">☁️</div>
        <div class="weather-temp" id="weather-temp">—°C</div>
        <div class="stat-label mt-1" id="weather-condition">—</div>
        <div class="d-flex gap-3 mt-2 justify-content-center" style="font-size:0.85rem;">
          <span>💧 <span id="weather-humidity">—</span>%</span>
          <span>🌬 <span id="weather-wind">—</span> km/h</span>
        </div>
      </div>
    </div>

    <!-- Widget 9: Duck Date/Time -->
    <div class="col-4">
      <div class="widget duck-widget">
        <h6>Date &amp; Time</h6>
        <div class="duck-emoji">🦆</div>
        <div class="duck-date" id="duck-date">—</div>
        <div class="duck-time" id="duck-time">—</div>
      </div>
    </div>

  </div><!-- /row -->
</div><!-- /container -->

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script>
  const DAYS = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];

  const pieColors = {
    green:  '#4caf50',
    yellow: '#ffeb3b',
    orange: '#ff9800',
    red:    '#f44336',
    grey:   '#9e9e9e',
  };

  const lineDefaults = {
    tension: 0.3,
    pointRadius: 3,
    borderWidth: 2,
    fill: false,
  };

  function gridOpts() {
    return {
      scales: {
        x: { ticks: { color: '#8a9bae' }, grid: { color: '#2e3443' } },
        y: { ticks: { color: '#8a9bae' }, grid: { color: '#2e3443' }, beginAtZero: true },
      },
    };
  }

  // ── Wazuh ──────────────────────────────────────────────────────────────────
  async function loadWazuh() {
    const d = await fetch('/api/wazuh').then(r => r.json());
    document.getElementById('wazuh-critical').textContent = d.count.critical;
    document.getElementById('wazuh-high').textContent     = d.count.high;
    new Chart(document.getElementById('wazuhChart'), {
      type: 'bar',
      data: {
        labels: d.history.map(h => h.day),
        datasets: [
          { label: 'Critical', data: d.history.map(h => h.critical), backgroundColor: '#ff5c5c' },
          { label: 'High',     data: d.history.map(h => h.high),     backgroundColor: '#ffb347' },
        ],
      },
      options: { ...gridOpts(), plugins: { legend: { labels: { color: '#8a9bae' } } }, scales: { ...gridOpts().scales, x: { ...gridOpts().scales.x, stacked: true }, y: { ...gridOpts().scales.y, stacked: true } } },
    });
  }

  // ── Atera ──────────────────────────────────────────────────────────────────
  async function loadAtera() {
    const d = await fetch('/api/atera').then(r => r.json());
    document.getElementById('atera-alerts').textContent  = d.active_alerts;
    document.getElementById('atera-tickets').textContent = d.open_tickets;
    document.getElementById('atera-patches').textContent = d.patching.pending_patches;
    new Chart(document.getElementById('ateraChart'), {
      type: 'line',
      data: {
        labels: d.history.map(h => h.day),
        datasets: [
          { label: 'Alerts',  data: d.history.map(h => h.alerts),  borderColor: '#42a5f5', ...lineDefaults },
          { label: 'Tickets', data: d.history.map(h => h.tickets), borderColor: '#ab47bc', ...lineDefaults },
        ],
      },
      options: { ...gridOpts(), plugins: { legend: { labels: { color: '#8a9bae' } } } },
    });
  }

  // ── Vipre ──────────────────────────────────────────────────────────────────
  async function loadVipre() {
    const d = await fetch('/api/vipre').then(r => r.json());
    document.getElementById('vipre-outdated').textContent = d.outdated_devices;
    document.getElementById('vipre-lost').textContent     = d.lost_devices;
    document.getElementById('vipre-no-av').textContent    = d.in_ad_no_av;
    document.getElementById('vipre-no-ad').textContent    = d.av_not_in_ad;
    new Chart(document.getElementById('vipreChart'), {
      type: 'line',
      data: {
        labels: d.history.map(h => h.day),
        datasets: [
          { label: 'Outdated',    data: d.history.map(h => h.outdated),    borderColor: '#ff5c5c', ...lineDefaults },
          { label: 'Lost',        data: d.history.map(h => h.lost),        borderColor: '#ffb347', ...lineDefaults },
          { label: 'AD w/o AV',  data: d.history.map(h => h.in_ad_no_av), borderColor: '#42a5f5', ...lineDefaults },
          { label: 'AV w/o AD',  data: d.history.map(h => h.av_not_in_ad),borderColor: '#66bb6a', ...lineDefaults },
        ],
      },
      options: { ...gridOpts(), plugins: { legend: { labels: { color: '#8a9bae' } } } },
    });
  }

  // ── Backup ─────────────────────────────────────────────────────────────────
  async function loadBackup() {
    const d = await fetch('/api/backup').then(r => r.json());
    new Chart(document.getElementById('backupChart'), {
      type: 'pie',
      data: {
        labels: ['Green','Yellow','Orange','Red','Grey'],
        datasets: [{
          data: [d.green, d.yellow, d.orange, d.red, d.grey],
          backgroundColor: Object.values(pieColors),
          offset: [0, 10, 15, 20, 5],
        }],
      },
      options: { plugins: { legend: { position: 'right', labels: { color: '#8a9bae' } } } },
    });
  }

  // ── AD Metrics ────────────────────────────────────────────────────────────
  async function loadAD() {
    const d = await fetch('/api/ad').then(r => r.json());
    document.getElementById('ad-expired').textContent = d.password_expired;
    document.getElementById('ad-locked').textContent  = d.locked_out;
    new Chart(document.getElementById('adChart'), {
      type: 'line',
      data: {
        labels: d.history.map(h => h.day),
        datasets: [
          { label: 'Pwd Expired', data: d.history.map(h => h.password_expired), borderColor: '#ef5350', ...lineDefaults },
          { label: 'Locked Out',  data: d.history.map(h => h.locked_out),       borderColor: '#ffa726', ...lineDefaults },
        ],
      },
      options: { ...gridOpts(), plugins: { legend: { labels: { color: '#8a9bae' } } } },
    });
  }

  // ── N-central ─────────────────────────────────────────────────────────────
  async function loadNcentral() {
    const d = await fetch('/api/ncentral').then(r => r.json());
    const typeColor = { Critical: '#f44336', Warning: '#ff9800', Failed: '#9e9e9e' };
    const tbody = document.getElementById('ncentral-body');
    tbody.innerHTML = d.alerts.map(a => {
      const t = new Date(a.transition_time);
      const since = t.toLocaleString('en-GB', { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' });
      const color = typeColor[a.type] || '#e0e0e0';
      return `<tr>
        <td>${a.device}</td>
        <td>${a.service}</td>
        <td style="color:${color};font-weight:600">${a.type}</td>
        <td>${since}</td>
      </tr>`;
    }).join('');
  }

  // ── Veeam ─────────────────────────────────────────────────────────────────
  async function loadVeeam() {
    const d = await fetch('/api/veeam').then(r => r.json());
    new Chart(document.getElementById('veeamChart'), {
      type: 'pie',
      data: {
        labels: ['Green','Yellow','Orange','Red','Grey'],
        datasets: [{
          data: [d.green, d.yellow, d.orange, d.red, d.grey],
          backgroundColor: Object.values(pieColors),
          offset: [0, 10, 15, 20, 5],
        }],
      },
      options: { plugins: { legend: { position: 'right', labels: { color: '#8a9bae' } } } },
    });
  }

  // ── Weather ───────────────────────────────────────────────────────────────
  const weatherIcons = {
    'partly-cloudy-day': '⛅',
    'clear-day':         '☀️',
    'rain':              '🌧️',
    'snow':              '❄️',
    'thunderstorm':      '⛈️',
    'cloudy':            '☁️',
  };
  async function loadWeather() {
    const d = await fetch('/api/weather').then(r => r.json());
    document.getElementById('weather-icon').textContent      = weatherIcons[d.icon] || '🌡️';
    document.getElementById('weather-temp').textContent      = `${d.temperature_c}°C`;
    document.getElementById('weather-condition').textContent = d.condition;
    document.getElementById('weather-humidity').textContent  = d.humidity_pct;
    document.getElementById('weather-wind').textContent      = d.wind_kmh;
  }

  // ── Datetime ──────────────────────────────────────────────────────────────
  async function loadDatetime() {
    const d = await fetch('/api/datetime').then(r => r.json());
    document.getElementById('duck-date').textContent = d.date;
    document.getElementById('duck-time').textContent = d.time;
  }

  // ── Boot ──────────────────────────────────────────────────────────────────
  Promise.all([
    loadWazuh(),
    loadAtera(),
    loadVipre(),
    loadBackup(),
    loadAD(),
    loadNcentral(),
    loadVeeam(),
    loadWeather(),
    loadDatetime(),
  ]);
</script>
</body>
</html>
