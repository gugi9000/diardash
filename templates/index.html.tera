<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Ducks in a Row Dashboard</title>
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />
  <style>
    body { background: #1a1d23; color: #e0e0e0; }
    .widget {
      background: #23272f;
      border-radius: 10px;
      padding: 1.25rem;
      height: 100%;
      min-height: 260px;
      display: flex;
      flex-direction: column;
    }
    .widget h6 {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #8a9bae;
      margin-bottom: 0.75rem;
    }
    .stat-value { font-size: 2rem; font-weight: 700; line-height: 1.1; }
    .stat-label { font-size: 0.8rem; color: #8a9bae; }
    .badge-critical { color: #ff5c5c; }
    .badge-high     { color: #ffb347; }
    .widget canvas  { flex: 1; }
    .duck-widget {
      align-items: center;
      justify-content: center;
      text-align: center;
    }
    .duck-emoji { font-size: 4rem; }
    .duck-date  { font-size: 1.1rem; font-weight: 600; margin-top: 0.5rem; }
    .duck-time  { font-size: 2.2rem; font-weight: 700; letter-spacing: 0.05em; }
    .load-status {
      width: 100%;
      margin-top: 1rem;
      padding-top: 0.9rem;
      border-top: 1px solid #33394a;
      text-align: left;
    }
    .load-status-title {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #8a9bae;
      margin-bottom: 0.6rem;
    }
    .load-status-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.45rem 1rem;
      font-size: 0.78rem;
    }
    .load-status-item {
      display: flex;
      justify-content: space-between;
      gap: 0.75rem;
      color: #c7d0dc;
    }
    .load-status-item span:last-child {
      color: #8a9bae;
      font-variant-numeric: tabular-nums;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      max-width: 14ch;
    }
    .load-indicator-ok { color: #66bb6a !important; }
    .load-indicator-fail { color: #ef5350 !important; }
    .load-indicator-pending { color: #8a9bae !important; }
    .ncentral-table { font-size: 0.8rem; }
    .ncentral-table th { color: #8a9bae; font-weight: 500; border-color: #33394a; }
    .ncentral-table td { border-color: #33394a; vertical-align: middle; }
    .weather-widget { align-items: center; justify-content: center; text-align: center; }
    .weather-temp { font-size: 3rem; font-weight: 700; }
    .weather-icon { font-size: 3rem; }
    .weather-source { font-size: 0.78rem; margin-top: 0.4rem; }
    .weather-source-live { color: #66bb6a; }
    .weather-source-fallback { color: #ffa726; }

    @media (min-width: 992px) {
      .dashboard-widget-duck { order: 1; }
      .dashboard-widget-wazuh { order: 2; }
      .dashboard-widget-weather { order: 3; }
      .dashboard-widget-atera { order: 4; }
      .dashboard-widget-vipre { order: 5; }
      .dashboard-widget-backup { order: 6; }
      .dashboard-widget-ad { order: 7; }
      .dashboard-widget-ncentral { order: 8; }
      .dashboard-widget-veeam { order: 9; }
    }
  </style>
</head>
<body>
<div class="container-fluid py-3 px-4">
  <h4 class="mb-3 fw-bold">🦆 Ducks in a Row</h4>
  <div class="row g-3">

    <!-- Widget 1: Wazuh -->
    <div class="col-4 dashboard-widget-wazuh">
      <div class="widget">
        <h6>Wazuh</h6>
        <div class="d-flex flex-wrap gap-3 mb-3">
          <div>
            <div class="stat-value badge-critical" id="wazuh-critical">—</div>
            <div class="stat-label">Critical</div>
          </div>
          <div>
            <div class="stat-value badge-high" id="wazuh-high">—</div>
            <div class="stat-label">High</div>
          </div>
          <div>
            <div class="stat-value" id="wazuh-active">—</div>
            <div class="stat-label">Active Devices</div>
          </div>
          <div>
            <div class="stat-value" id="wazuh-disconnected">—</div>
            <div class="stat-label">Disconnected Devices</div>
          </div>
        </div>
        <canvas id="wazuhChart"></canvas>
      </div>
    </div>

    <!-- Widget 2: Atera -->
    <div class="col-4 dashboard-widget-atera">
      <div class="widget">
        <h6>Atera</h6>
        <div class="d-flex gap-4 mb-3">
          <div>
            <div class="stat-value" id="atera-alerts">—</div>
            <div class="stat-label">Active Alerts</div>
          </div>
          <div>
            <div class="stat-value" id="atera-tickets">—</div>
            <div class="stat-label">Open Tickets</div>
          </div>
          <div>
            <div class="stat-value" id="atera-patches">—</div>
            <div class="stat-label">Pending Patches</div>
          </div>
        </div>
        <canvas id="ateraChart"></canvas>
      </div>
    </div>

    <!-- Widget 3: Vipre AV -->
    <div class="col-4 dashboard-widget-vipre">
      <div class="widget">
        <h6>Vipre AV</h6>
        <div class="d-flex flex-wrap gap-3 mb-3">
          <div>
            <div class="stat-value" id="vipre-outdated">—</div>
            <div class="stat-label">Outdated</div>
          </div>
          <div>
            <div class="stat-value" id="vipre-lost">—</div>
            <div class="stat-label">Lost</div>
          </div>
          <div>
            <div class="stat-value" id="vipre-no-av">—</div>
            <div class="stat-label">AD w/o AV</div>
          </div>
          <div>
            <div class="stat-value" id="vipre-no-ad">—</div>
            <div class="stat-label">AV w/o AD</div>
          </div>
        </div>
        <canvas id="vipreChart"></canvas>
      </div>
    </div>

    <!-- Widget 4: Backup -->
    <div class="col-4 dashboard-widget-backup">
      <div class="widget">
        <h6>Backup Status</h6>
        <canvas id="backupChart"></canvas>
      </div>
    </div>

    <!-- Widget 5: AD Metrics -->
    <div class="col-4 dashboard-widget-ad">
      <div class="widget">
        <h6>AD Metrics</h6>
        <div class="d-flex gap-4 mb-3">
          <div>
            <div class="stat-value" id="ad-expired">—</div>
            <div class="stat-label">Pwd Expired</div>
          </div>
          <div>
            <div class="stat-value" id="ad-locked">—</div>
            <div class="stat-label">Locked Out</div>
          </div>
        </div>
        <canvas id="adChart"></canvas>
      </div>
    </div>

    <!-- Widget 6: N-central -->
    <div class="col-4 dashboard-widget-ncentral">
      <div class="widget">
        <h6>N-central Alerts</h6>
        <div class="table-responsive">
          <table class="table table-dark table-sm ncentral-table mb-0">
            <thead>
              <tr>
                <th>Device</th>
                <th>Service</th>
                <th>Type</th>
                <th>Since</th>
              </tr>
            </thead>
            <tbody id="ncentral-body">
              <tr><td colspan="4" class="text-center text-secondary">Loading…</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Widget 7: Veeam -->
    <div class="col-4 dashboard-widget-veeam">
      <div class="widget">
        <h6>Veeam Jobs</h6>
        <canvas id="veeamChart"></canvas>
      </div>
    </div>

    <!-- Widget 8: Weather -->
    <div class="col-4 dashboard-widget-weather">
      <div class="widget weather-widget">
        <h6>Weather</h6>
        <div class="weather-icon" id="weather-icon">☁️</div>
        <div class="weather-temp" id="weather-temp">—°C</div>
        <div class="stat-label mt-1" id="weather-condition">—</div>
        <div class="weather-source" id="weather-source">⏳ Waiting for weather source</div>
        <div class="d-flex gap-3 mt-2 justify-content-center" style="font-size:0.85rem;">
          <span>💧 <span id="weather-humidity">—</span>%</span>
          <span>🌬 <span id="weather-wind">—</span> km/h</span>
        </div>
      </div>
    </div>

    <!-- Widget 9: Duck Date/Time -->
    <div class="col-4 dashboard-widget-duck">
      <div class="widget duck-widget">
        <h6>Date &amp; Time</h6>
        <div class="duck-emoji">🦆</div>
        <div class="duck-date" id="duck-date">—</div>
        <div class="duck-time" id="duck-time">—</div>
        <div class="load-status">
          <div class="load-status-title">Last Loaded</div>
          <div class="load-status-grid">
            <div class="load-status-item"><span>Wazuh</span><span id="loaded-wazuh" class="load-indicator-pending">⏳ —</span></div>
            <div class="load-status-item"><span>Atera</span><span id="loaded-atera" class="load-indicator-pending">⏳ —</span></div>
            <div class="load-status-item"><span>Vipre AV</span><span id="loaded-vipre" class="load-indicator-pending">⏳ —</span></div>
            <div class="load-status-item"><span>Backup</span><span id="loaded-backup" class="load-indicator-pending">⏳ —</span></div>
            <div class="load-status-item"><span>AD Metrics</span><span id="loaded-ad" class="load-indicator-pending">⏳ —</span></div>
            <div class="load-status-item"><span>N-central</span><span id="loaded-ncentral" class="load-indicator-pending">⏳ —</span></div>
            <div class="load-status-item"><span>Veeam</span><span id="loaded-veeam" class="load-indicator-pending">⏳ —</span></div>
            <div class="load-status-item"><span>Weather</span><span id="loaded-weather" class="load-indicator-pending">⏳ —</span></div>
            <div class="load-status-item"><span>Date &amp; Time</span><span id="loaded-datetime" class="load-indicator-pending">⏳ —</span></div>
          </div>
        </div>
      </div>
    </div>

  </div><!-- /row -->
</div><!-- /container -->

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script>
  const DAYS = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];

  const pieColors = {
    green:  '#008040',
    yellow: '#ffeb3b',
    orange: '#ff9800',
    red:    '#f44336',
    grey:   '#9e9e9e',
  };

  const lineDefaults = {
    tension: 0.3,
    pointRadius: 3,
    borderWidth: 2,
    fill: false,
  };

  const chartInstances = {};

  const refreshIntervals = {
    wazuh: 60 * 60 * 1000,
    atera: 10 * 60 * 1000,
    vipre: 60 * 60 * 1000,
    backup: 2 * 60 * 60 * 1000,
    ad: 2 * 60 * 60 * 1000,
    ncentral: 5 * 60 * 1000,
    veeam: 2 * 60 * 60 * 1000,
    weather: 30 * 60 * 1000,
  };

  function gridOpts() {
    return {
      scales: {
        x: { ticks: { color: '#8a9bae' }, grid: { color: '#2e3443' } },
        y: { ticks: { color: '#8a9bae' }, grid: { color: '#2e3443' }, beginAtZero: true },
      },
    };
  }

  function formatLoadedTime(date = new Date()) {
    return new Intl.DateTimeFormat('en-GB', {
      hour: '2-digit',
      minute: '2-digit',
      second: '2-digit',
      hour12: false,
    }).format(date);
  }

  async function fetchJson(url) {
    const response = await fetch(url);
    if (!response.ok) {
      throw new Error(`HTTP ${response.status} from ${url}`);
    }

    return response.json();
  }

  function shortenErrorReason(reason) {
    if (!reason) {
      return '';
    }

    const clean = String(reason).replace(/\s+/g, ' ').trim();
    if (clean.length <= 20) {
      return clean;
    }

    return `${clean.slice(0, 19)}…`;
  }

  function setWidgetLoadState(widget, status, loadedAt = new Date(), reason = '') {
    const element = document.getElementById(`loaded-${widget}`);
    if (!element) {
      return;
    }

    const statusConfig = {
      ok:   { emoji: '✅', className: 'load-indicator-ok' },
      fail: { emoji: '❌', className: 'load-indicator-fail' },
    };

    const config = statusConfig[status] || statusConfig.fail;
    element.classList.remove('load-indicator-ok', 'load-indicator-fail', 'load-indicator-pending');
    element.classList.add(config.className);
    const timeText = formatLoadedTime(loadedAt);
    const shortReason = status === 'fail' ? shortenErrorReason(reason) : '';
    element.textContent = shortReason ? `${config.emoji} ${timeText} ${shortReason}` : `${config.emoji} ${timeText}`;
    element.title = reason || '';
  }

  function markWidgetLoadSuccess(widget, loadedAt = new Date()) {
    setWidgetLoadState(widget, 'ok', loadedAt, 'Last reload succeeded');
  }

  function markWidgetLoadFailure(widget, loadedAt = new Date(), reason = 'Reload failed') {
    setWidgetLoadState(widget, 'fail', loadedAt, reason);
  }

  function getWidgetErrorMessage(error) {
    if (error && typeof error === 'object' && 'message' in error) {
      return error.message;
    }

    return String(error);
  }

  function renderChart(canvasId, config) {
    if (chartInstances[canvasId]) {
      chartInstances[canvasId].destroy();
    }

    chartInstances[canvasId] = new Chart(document.getElementById(canvasId), config);
  }

  async function runWidgetLoader(widget, loader) {
    const loadedAt = new Date();

    try {
      await loader();
      markWidgetLoadSuccess(widget, loadedAt);
    } catch (error) {
      const reason = getWidgetErrorMessage(error);
      console.error(`Failed to load ${widget}: ${reason}`);
      markWidgetLoadFailure(widget, loadedAt, reason);
    }
  }

  function startWidgetRefresh(widget, loader, intervalMs) {
    runWidgetLoader(widget, loader);

    if (intervalMs) {
      window.setInterval(() => {
        runWidgetLoader(widget, loader);
      }, intervalMs);
    }
  }

  // ── Wazuh ──────────────────────────────────────────────────────────────────
  async function loadWazuh() {
    const d = await fetchJson('/api/wazuh');
    document.getElementById('wazuh-critical').textContent     = d.count.critical;
    document.getElementById('wazuh-high').textContent         = d.count.high;
    document.getElementById('wazuh-active').textContent       = d.count.active_devices;
    document.getElementById('wazuh-disconnected').textContent = d.count.disconnected_devices;
    renderChart('wazuhChart', {
      type: 'bar',
      data: {
        labels: d.history.map(h => h.day),
        datasets: [
          {
            label: 'Active Devices',
            data: d.history.map(h => h.active_devices),
            backgroundColor: '#42a5f5',
            stack: 'devices',
            yAxisID: 'yDevices',
            order: 2,
          },
          {
            label: 'Disconnected Devices',
            data: d.history.map(h => h.disconnected_devices),
            backgroundColor: '#78909c',
            stack: 'devices',
            yAxisID: 'yDevices',
            order: 2,
          },
          {
            label: 'Critical',
            data: d.history.map(h => h.critical),
            borderColor: '#ff5c5c',
            backgroundColor: '#ff5c5c',
            type: 'line',
            yAxisID: 'yAlerts',
            order: 1,
            ...lineDefaults,
          },
          {
            label: 'High',
            data: d.history.map(h => h.high),
            borderColor: '#ffb347',
            backgroundColor: '#ffb347',
            type: 'line',
            yAxisID: 'yAlerts',
            order: 1,
            ...lineDefaults,
          },
        ],
      },
      options: {
        interaction: { mode: 'index', intersect: false },
        plugins: { legend: { labels: { color: '#8a9bae' } } },
        scales: {
          x: { ticks: { color: '#8a9bae' }, grid: { color: '#2e3443' }, stacked: true },
          yDevices: {
            beginAtZero: true,
            position: 'left',
            stacked: true,
            ticks: { color: '#8a9bae' },
            grid: { color: '#2e3443' },
            title: { display: true, text: 'Devices', color: '#8a9bae' },
          },
          yAlerts: {
            beginAtZero: true,
            position: 'right',
            ticks: { color: '#8a9bae' },
            grid: { drawOnChartArea: false },
            title: { display: true, text: 'Alerts', color: '#8a9bae' },
          },
        },
      },
    });
  }

  // ── Atera ──────────────────────────────────────────────────────────────────
  async function loadAtera() {
    const d = await fetchJson('/api/atera');
    document.getElementById('atera-alerts').textContent  = d.active_alerts;
    document.getElementById('atera-tickets').textContent = d.open_tickets;
    document.getElementById('atera-patches').textContent = d.patching.pending_patches;
    renderChart('ateraChart', {
      type: 'line',
      data: {
        labels: d.history.map(h => h.day),
        datasets: [
          { label: 'Alerts',  data: d.history.map(h => h.alerts),  borderColor: '#42a5f5', ...lineDefaults },
          { label: 'Tickets', data: d.history.map(h => h.tickets), borderColor: '#ab47bc', ...lineDefaults },
        ],
      },
      options: { ...gridOpts(), plugins: { legend: { labels: { color: '#8a9bae' } } } },
    });
  }

  // ── Vipre ──────────────────────────────────────────────────────────────────
  async function loadVipre() {
    const d = await fetchJson('/api/vipre');
    document.getElementById('vipre-outdated').textContent = d.outdated_devices;
    document.getElementById('vipre-lost').textContent     = d.lost_devices;
    document.getElementById('vipre-no-av').textContent    = d.in_ad_no_av;
    document.getElementById('vipre-no-ad').textContent    = d.av_not_in_ad;
    renderChart('vipreChart', {
      type: 'line',
      data: {
        labels: d.history.map(h => h.day),
        datasets: [
          { label: 'Outdated',    data: d.history.map(h => h.outdated),    borderColor: '#ff5c5c', ...lineDefaults },
          { label: 'Lost',        data: d.history.map(h => h.lost),        borderColor: '#ffb347', ...lineDefaults },
          { label: 'AD w/o AV',  data: d.history.map(h => h.in_ad_no_av), borderColor: '#42a5f5', ...lineDefaults },
          { label: 'AV w/o AD',  data: d.history.map(h => h.av_not_in_ad),borderColor: '#66bb6a', ...lineDefaults },
        ],
      },
      options: { ...gridOpts(), plugins: { legend: { labels: { color: '#8a9bae' } } } },
    });
  }

  // ── Backup ─────────────────────────────────────────────────────────────────
  async function loadBackup() {
    const d = await fetchJson('/api/backup');
    renderChart('backupChart', {
      type: 'pie',
      data: {
        labels: ['Green','Yellow','Orange','Red','Grey'],
        datasets: [{
          data: [d.green, d.yellow, d.orange, d.red, d.grey],
          backgroundColor: Object.values(pieColors),
          offset: [0, 10, 15, 20, 5],
        }],
      },
      options: { plugins: { legend: { position: 'right', labels: { color: '#8a9bae' } } } },
    });
  }

  // ── AD Metrics ────────────────────────────────────────────────────────────
  async function loadAD() {
    const d = await fetchJson('/api/ad');
    document.getElementById('ad-expired').textContent = d.password_expired;
    document.getElementById('ad-locked').textContent  = d.locked_out;
    renderChart('adChart', {
      type: 'line',
      data: {
        labels: d.history.map(h => h.day),
        datasets: [
          { label: 'Pwd Expired', data: d.history.map(h => h.password_expired), borderColor: '#ef5350', ...lineDefaults },
          { label: 'Locked Out',  data: d.history.map(h => h.locked_out),       borderColor: '#ffa726', ...lineDefaults },
        ],
      },
      options: { ...gridOpts(), plugins: { legend: { labels: { color: '#8a9bae' } } } },
    });
  }

  // ── N-central ─────────────────────────────────────────────────────────────
  async function loadNcentral() {
    const d = await fetchJson('/api/ncentral');
    const typeColor = { Critical: '#f44336', Warning: '#ff9800', Failed: '#9e9e9e' };
    const tbody = document.getElementById('ncentral-body');
    tbody.innerHTML = d.alerts.map(a => {
      const t = new Date(a.transition_time);
      const since = t.toLocaleString('en-GB', { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' });
      const color = typeColor[a.type] || '#e0e0e0';
      return `<tr>
        <td>${a.device}</td>
        <td>${a.service}</td>
        <td style="color:${color};font-weight:600">${a.type}</td>
        <td>${since}</td>
      </tr>`;
    }).join('');
  }

  // ── Veeam ─────────────────────────────────────────────────────────────────
  async function loadVeeam() {
    const d = await fetchJson('/api/veeam');
    renderChart('veeamChart', {
      type: 'pie',
      data: {
        labels: ['Green','Yellow','Orange','Red','Grey'],
        datasets: [{
          data: [d.green, d.yellow, d.orange, d.red, d.grey],
          backgroundColor: Object.values(pieColors),
          offset: [0, 10, 15, 20, 5],
        }],
      },
      options: { plugins: { legend: { position: 'right', labels: { color: '#8a9bae' } } } },
    });
  }

  // ── Weather ───────────────────────────────────────────────────────────────
  const weatherIcons = {
    'partly-cloudy-day': '⛅',
    'clear-day':         '☀️',
    'rain':              '🌧️',
    'snow':              '❄️',
    'thunderstorm':      '⛈️',
    'cloudy':            '☁️',
  };
  async function loadWeather() {
    const d = await fetchJson('/api/weather');
    const sourceElement = document.getElementById('weather-source');
    document.getElementById('weather-icon').textContent      = weatherIcons[d.icon] || '🌡️';
    document.getElementById('weather-temp').textContent      = `${d.temperature_c}°C`;
    document.getElementById('weather-condition').textContent = d.condition;
    document.getElementById('weather-humidity').textContent  = d.humidity_pct;
    document.getElementById('weather-wind').textContent      = d.wind_kmh;

    sourceElement.classList.remove('weather-source-live', 'weather-source-fallback');
    if (d.fallback_used) {
      sourceElement.classList.add('weather-source-fallback');
      sourceElement.textContent = `⚠️ Fallback in use (${d.source || 'mock'})`;
    } else {
      sourceElement.classList.add('weather-source-live');
      sourceElement.textContent = `✅ Live source (${d.source || 'openweather'})`;
    }
  }

  // ── Datetime ──────────────────────────────────────────────────────────────
  let duckNow = null;
  let duckTickTimer = null;
  let duckSyncTimer = null;

  function formatDuckDate(date) {
    const parts = new Intl.DateTimeFormat('en-US', {
      weekday: 'long',
      month: 'long',
      day: 'numeric',
      year: 'numeric',
    }).formatToParts(date);
    const values = Object.fromEntries(parts.map(part => [part.type, part.value]));
    return `${values.weekday}, ${values.month} ${values.day} ${values.year}`;
  }

  function formatDuckTime(date) {
    return new Intl.DateTimeFormat('en-GB', {
      hour: '2-digit',
      minute: '2-digit',
      second: '2-digit',
      hour12: false,
    }).format(date);
  }

  function renderDatetime() {
    if (!duckNow) {
      return;
    }

    document.getElementById('duck-date').textContent = formatDuckDate(duckNow);
    document.getElementById('duck-time').textContent = formatDuckTime(duckNow);
  }

  function tickDatetime() {
    if (!duckNow) {
      return;
    }

    duckNow = new Date(duckNow.getTime() + 1000);
    renderDatetime();
  }

  async function syncDatetime() {
    const d = await fetchJson('/api/datetime');
    duckNow = new Date(d.timestamp);

    if (Number.isNaN(duckNow.getTime())) {
      throw new Error('Invalid datetime timestamp from API');
    }

    renderDatetime();
  }

  function startDatetimeRefresh() {
    runWidgetLoader('datetime', syncDatetime);

    if (!duckTickTimer) {
      duckTickTimer = window.setInterval(tickDatetime, 1000);
    }

    if (!duckSyncTimer) {
      duckSyncTimer = window.setInterval(() => runWidgetLoader('datetime', syncDatetime), 60000);
    }
  }

  // ── Boot ──────────────────────────────────────────────────────────────────
  startWidgetRefresh('wazuh', loadWazuh, refreshIntervals.wazuh);
  startWidgetRefresh('atera', loadAtera, refreshIntervals.atera);
  startWidgetRefresh('vipre', loadVipre, refreshIntervals.vipre);
  startWidgetRefresh('backup', loadBackup, refreshIntervals.backup);
  startWidgetRefresh('ad', loadAD, refreshIntervals.ad);
  startWidgetRefresh('ncentral', loadNcentral, refreshIntervals.ncentral);
  startWidgetRefresh('veeam', loadVeeam, refreshIntervals.veeam);
  startWidgetRefresh('weather', loadWeather, refreshIntervals.weather);

  startDatetimeRefresh();
</script>
</body>
</html>
